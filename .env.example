# Copy this file to .env.local and fill in your Supabase project values
# Get these from your Supabase project dashboard: Settings → API

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Weather: no key needed — using Open-Meteo (free)
# Default city for weather widget if user hasn't set one
NEXT_PUBLIC_DEFAULT_CITY=London
NEXT_PUBLIC_DEFAULT_LAT=51.5074
NEXT_PUBLIC_DEFAULT_LON=-0.1278

# Reserved for v2 — Gmail integration
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
